{
  "version": 2,
  "buildCommand": "cd slook && npm install && npm run build",
  "outputDirectory": "slook/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["bom1"],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://slook-backend.onrender.com/api/$1"
    }
  ]
}
